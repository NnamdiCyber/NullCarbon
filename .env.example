# NullCarbon Environment Configuration
# Copy this file to .env and fill in your values

# Stellar Network Configuration
STELLAR_NETWORK=testnet                            # Network: testnet | mainnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org # Soroban RPC endpoint
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org # Horizon API endpoint
STELLAR_PASSPHRASE="Test SDF Network ; September 2015" # Network passphrase

# Deployer Account (funded testnet account)
DEPLOYER_SECRET_KEY=S...                           # Deployer secret key (base64)
DEPLOYER_PUBLIC_KEY=G...                           # Deployer public key (G...)

# Contract IDs — populated after deployment
RETIREMENT_VERIFIER_ID=C...                        # RetirementVerifier contract
NULLIFIER_REGISTRY_ID=C...                         # NullifierRegistry contract
CREDIT_REGISTRY_ID=C...                            # CreditRegistry contract
