# NullCarbon Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000

# Stellar Network
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_PASSPHRASE="Test SDF Network ; September 2015"

# Soroban Contract IDs (populated after deployment)
RETIREMENT_VERIFIER_ID=C...
NULLIFIER_REGISTRY_ID=C...
CREDIT_REGISTRY_ID=C...

# Carbon Registry API Keys
VERRA_API_KEY=your_verra_api_key
GOLD_STANDARD_API_KEY=your_gs_api_key

# Database
DATABASE_URL=postgres://nullcarbon:nullcarbon@localhost:5432/nullcarbon

# Merkle Tree Configuration
MERKLE_TREE_DEPTH=20

# JWT Secret for API authentication
JWT_SECRET=your_jwt_secret
